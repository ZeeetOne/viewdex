generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  name      String?
  avatarUrl String?
  role      UserRole @default(USER)

  // OAuth tracking
  provider AuthProvider @default(EMAIL)

  // Track username changes (30-day cooldown)
  usernameChangedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mediaItems MediaItem[]
}

enum UserRole {
  USER
  ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

model MediaItem {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Media Info
  title      String
  type       MediaType
  category   MediaCategory
  imageUrl   String?
  totalUnits Int? // episodes for watch, chapters for read (null = ongoing)

  // Tracking
  status   TrackStatus @default(PLANNED)
  progress Int         @default(0) // current episode/chapter
  rating   Int? // 1-10, null = not rated
  notes    String?

  // Timestamps
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, type])
  @@index([userId, category])
}

enum MediaCategory {
  WATCH
  READ
}

enum MediaType {
  // Watch (episodes)
  ANIME
  DONGHUA
  AENI
  WESTERN_ANIMATION
  // Read (chapters)
  MANGA
  MANHWA
  MANHUA
  WESTERN_COMIC
  // Custom
  OTHER
}

enum TrackStatus {
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  DROPPED
  PLANNED
}
